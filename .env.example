# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://qbnizuhozzwkiitfkjee.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Required by the SMS API routes.
SUPABASE_SERVICE_ROLE_KEY=

# Google Maps (places autocomplete)
GOOGLE_MAPS_API_KEY=

# Twilio (shared account for SMS + WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
# Sender number (the legacy production sender is +18774608995)
TWILIO_FROM_NUMBER=+18774608995
# Public base URL used to validate webhook signatures, e.g. https://app.primewillcall.com
TWILIO_WEBHOOK_BASE_URL=
# Set to "false" ONLY for local development without real Twilio requests
TWILIO_VALIDATE_SIGNATURE=

# Booking ticket link base (legacy short domain)
BOOKING_LINK_BASE_URL=https://bked.io/booking

# Stripe (payments). Use Prime's PLATFORM account keys (the same account whose
# connected accounts back each business), NOT a personal/test account.
# Server-only secret key. A restricted key (rk_...) is preferred over sk_...
STRIPE_SECRET_KEY=
# Publishable key (browser-safe). Reserved for future embedded checkout.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Signing secret for the PLATFORM webhook endpoint (Stripe dashboard).
STRIPE_WEBHOOK_SECRET=
# Signing secret for the CONNECT webhook endpoint (connected-account events).
STRIPE_WEBHOOK_SECRET_CONNECTED=
# Global platform (Prime) fee in basis points. 25 = 0.25% (Stripe's Connect fee,
# passed through as the application fee on every direct charge).
STRIPE_PLATFORM_FEE_BPS=25
# Absolute app base URL for Stripe redirect/return URLs, e.g. https://app.primewillcall.com
NEXT_PUBLIC_APP_URL=

# Coexistence with Xano: inbound webhooks are mirrored to this URL so the Xano
# flow keeps working. Defaults to the live Xano endpoint; set to "" at final cutover.
XANO_SMS_FORWARD_URL=https://xmhi-aj9d-cnsb.n7.xano.io/api:M7vqYZvJ/receive/sms_respose_twilio
